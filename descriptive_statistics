    "def generate_statistics_df(std_limit, save_excel='no', excel_name='Statistics', cell_width=50):\n",
    "    # Retrieve all dataframe variables from the global namespace that match df1, df2, df3, etc.\n",
    "    dataframe_names = [var for var in globals() if var.startswith('df') and var[2:].isdigit() and isinstance(globals()[var], pd.DataFrame)]\n",
    "\n",
    "    # Initialize an empty dictionary to hold statistics for each dataframe\n",
    "    all_stats = {}\n",
    "\n",
    "    # Compute statistics for each dataframe and store the results\n",
    "    for name in dataframe_names:\n",
    "        df = globals()[name]\n",
    "        stats = compute_statistics(df, std_limit=std_limit)\n",
    "        all_stats[name] = stats\n",
    "\n",
    "    # Combine all statistics into a single dataframe\n",
    "    statistics_df = pd.concat(all_stats, axis=1)\n",
    "    if save_excel == 'yes':\n",
    "        statistics_df.to_excel(f\"{excel_name}.xlsx\")\n",
    "        wb = load_workbook(f\"{excel_name}.xlsx\")\n",
    "\n",
    "        # Adjust dimensions automatically\n",
    "        adjust_dimensions(wb, max_column_width=cell_width)\n",
    "\n",
    "        # Save the workbook with the adjusted dimensions\n",
    "        wb.save(f\"{excel_name}.xlsx\")\n",
    "\n",
    "    return statistics_df\n",
    "\n",
    "#generate_statistics_df(std_limit=-2)"
