    "\n",
    "    plot_number = 1\n",
    "\n",
    "    # Ensure the output directory exists\n",
    "    if not os.path.exists(folder_name):\n",
    "        os.makedirs(folder_name)\n",
    "\n",
    "    for name in dataframe_names:\n",
    "        if not smooth_data:\n",
    "            df = globals()[name]\n",
    "        else:\n",
    "            df_number = int(name[2:])\n",
    "            dataframe_list = smooth_dataframe(svgal_window=svgal_window, polyorder=polyorder)\n",
    "            df = dataframe_list[df_number - 1]\n",
    "\n",
    "        stats = statistics_df[name]\n",
    "\n",
    "        for column in df.columns:\n",
    "            #print(f'{plot_number}. {column}')\n",
    "            plt.figure(figsize=(12, 6))\n",
    "            plt.plot(df.index, df[column], label=f'{name}.{column}')\n",
    "            plt.title(f'{column}')\n",
    "            plt.xlabel('Index')\n",
    "            plt.ylabel(column)\n",
    "\n",
    "            median_value = stats[column]['median value']\n",
    "            mad_around_median = stats[column]['mean absolute deviation around median']\n",
    "            mean_value = stats[column]['mean value']\n",
    "            std_around_mean = stats[column]['standard deviation value']\n",
    "\n",
    "            plt.axhline(median_value, color='orange', linestyle='-', label='Median')\n",
    "            plt.axhline(mean_value + std_around_mean, color='red', linestyle='--', label='Mean + STD', linewidth=0.75)\n",
    "            plt.axhline(mean_value - std_around_mean, color='red', linestyle='--', label='Mean - STD', linewidth=0.75)\n",
    "            plt.axhline(mean_value + 2 * std_around_mean, color='grey', linestyle='--', label='Mean + 2STD', linewidth=0.5)\n",
    "            plt.axhline(mean_value - 2 * std_around_mean, color='grey', linestyle='--', label='Mean - 2STD', linewidth=0.5)\n",
    "\n",
    "            lower_bound = mean_value - (zoom_std * std_around_mean)\n",
    "            upper_bound = mean_value + (zoom_std * std_around_mean)\n",
    "            plt.ylim(lower_bound, upper_bound)\n",
    "\n",
    "            annotation = (f\"Current Value: {stats[column]['current value']:.2f}\\n\"\n",
