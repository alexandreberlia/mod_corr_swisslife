    "    # Define the fill colors\n",
    "    blue_fill = PatternFill(start_color='0000FF', end_color='0000FF', fill_type='solid')\n",
    "    red_fill = PatternFill(start_color='FF0000', end_color='FF0000', fill_type='solid')\n",
    "    yellow_fill = PatternFill(start_color='FFFF00', end_color='FFFF00', fill_type='solid')\n",
    "\n",
    "    # Apply conditional formatting based on cell values\n",
    "    for row in sheet.iter_rows(min_row=2, min_col=2, max_row=sheet.max_row, max_col=sheet.max_column):\n",
    "        for cell in row:\n",
    "            if cell.value == 'a':\n",
    "                cell.fill = blue_fill\n",
    "            elif cell.value == 'b':\n",
    "                cell.fill = red_fill\n",
    "            elif cell.value == 'ab':\n",
    "                cell.fill = yellow_fill\n",
    "\n",
    "    # Save the modified workbook\n",
    "    workbook.save(f'Categorized_colored_values_above_below_{std_limit}_standard_deviations.xlsx')\n",
