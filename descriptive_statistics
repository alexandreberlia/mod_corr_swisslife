    "def compute_statistics(df, std_limit, save_excel = 'no', excel_name = 'Statistics', cell_width = 50):\n",
    "    stats = {}\n",
    "    \n",
    "    for col in df.columns:\n",
    "        above_std_dates = []\n",
    "        current_value = df[col].iloc[-1]\n",
    "        median_value = df[col].median()\n",
    "        mean_value = df[col].mean()\n",
    "        std_dev = df[col].std()\n",
    "        deviations = df[col] - median_value\n",
    "        median_absolute_deviation = deviations.abs().mean()\n",
    "\n",
    "        above_mean = current_value > mean_value\n",
    "        above_median = current_value > median_value\n",
    "\n",
    "        # Calculate the range of standard deviations the current value is in\n",
    "        what_std = 0\n",
    "        if above_mean:\n",
    "            while current_value > mean_value + (what_std + 1) * std_dev:\n",
    "                what_std += 1\n",
    "            what_std += 1\n",
    "        else:\n",
    "            while current_value < mean_value - (what_std + 1) * std_dev:\n",
    "                what_std += 1\n",
    "            what_std += 1\n",
    "            what_std = -what_std\n",
    "\n",
    "        # Adjust std_limit based on the column name\n",
    "        effective_std_limit = -std_limit if ('(Inflation)' in col) or ('US GDP Price Index QoQ SAAR (GDP)' in col) else std_limit\n",
    "\n",
    "        if effective_std_limit > 0:\n",
    "            above_std = df[col] > (mean_value + effective_std_limit * std_dev)\n",
    "        else:\n",
    "            above_std = df[col] < (mean_value + effective_std_limit * std_dev)\n",
    "        above_std_start_dates = above_std[above_std & ~above_std.shift(1, fill_value=False)].index\n",
    "        above_std_dates.extend([[date.date(), col] for date in above_std_start_dates])\n",
    "\n",
    "        stats[col] = {\n",
    "            'current value': current_value,\n",
    "            'minimum value': df[col].min(),\n",
    "            'date at which minimum value is reached': df[col].idxmin().date(),\n",
    "            'maximum value': df[col].max(),\n",
    "            'date at which maximum value is reached': df[col].idxmax().date(),\n",
    "            'median value': median_value,\n",
    "            'mean value': mean_value,\n",
    "            'standard deviation value': std_dev,\n",
    "            'mean absolute deviation around median': median_absolute_deviation,\n",
    "            'above mean': above_mean,\n",
    "            'above median': above_median,\n",
    "            'what std': what_std,\n",
    "            f'dates above {std_limit} stds': above_std_dates\n",
    "        }\n",
    "    df_stats = pd.DataFrame(stats)\n",
    "    if save_excel == 'yes':\n",
    "        df_stats.to_excel(f\"{excel_name}.xlsx\")\n",
    "        wb = load_workbook(f\"{excel_name}.xlsx\")\n",
    "\n",
    "        # Adjust dimensions automatically\n",
    "        adjust_dimensions(wb, max_column_width=cell_width)\n",
    "\n",
    "        # Save the workbook with the adjusted dimensions\n",
    "        wb.save(f\"{excel_name}.xlsx\")\n",
    "    return df_stats\n",
    "#compute_statistics(df27, std_limit=2)"
