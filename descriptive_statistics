    "def find_dates_above_below_stds(std_limit, save_excel='no', excel_name='Dates Above Below Stds', cell_width=50):\n",
    "    statistics_df = generate_statistics_df(std_limit=std_limit)\n",
    "    series = {}\n",
    "    negative_statistics_df = generate_statistics_df(std_limit=-std_limit)\n",
    "\n",
    "    for df_name in statistics_df.columns:\n",
    "        dates_above_std = statistics_df[df_name].iloc[12]\n",
    "        for j in range(len(dates_above_std)):\n",
    "            date, column = dates_above_std[j]\n",
    "            year = date.year\n",
    "            month = date.month\n",
    "            month_year = (year, month)\n",
    "            category = column.split('(')[-1].rstrip(')')\n",
    "            if (category, column) not in series:\n",
    "                series[(category, column)] = {}\n",
    "            if month_year not in series[(category, column)]:\n",
    "                series[(category, column)][month_year] = 'a'\n",
    "            else:\n",
    "                if 'a' not in series[(category, column)][month_year]:\n",
    "                    series[(category, column)][month_year] += 'a'\n",
    "\n",
    "    for df_name in negative_statistics_df.columns:\n",
    "        dates_below_std = negative_statistics_df[df_name].iloc[12]\n",
    "        for j in range(len(dates_below_std)):\n",
    "            date, column = dates_below_std[j]\n",
    "            year = date.year\n",
    "            month = date.month\n",
    "            month_year = (year, month)\n",
    "            category = column.split('(')[-1].rstrip(')')\n",
    "            if (category, column) not in series:\n",
    "                series[(category, column)] = {}\n",
    "            if month_year not in series[(category, column)]:\n",
    "                series[(category, column)][month_year] = 'b'\n",
    "            else:\n",
    "                if 'b' not in series[(category, column)][month_year]:\n",
    "                    series[(category, column)][month_year] += 'b'\n",
    "\n",
    "    # Convert the dictionary to a DataFrame\n",
    "    result_df = pd.DataFrame(series).transpose().fillna('')\n",
    "\n",
    "    # Sort the DataFrame by the column (year) index\n",
    "    result_df = result_df.sort_index(axis=1)\n",
    "\n",
    "    # Sort the DataFrame by the category and column name\n",
    "    result_df.index = pd.MultiIndex.from_tuples(result_df.index, names=['Category', 'Column'])\n",
    "    result_df = result_df.sort_index(level=['Category', 'Column'])\n",
    "    result_df.index = result_df.index.map(lambda x: f\"{x[1]}\")\n",
    "    result_df.index.name = None\n",
    "    if save_excel == \"yes\":\n",
    "        result_df.to_excel(f\"{excel_name}.xlsx\")\n",
    "        wb = load_workbook(f\"{excel_name}.xlsx\")\n",
    "\n",
    "        # Adjust dimensions automatically\n",
    "        adjust_dimensions(wb, max_column_width=cell_width)\n",
    "\n",
    "        # Save the workbook with the adjusted dimensions\n",
    "        wb.save(f\"{excel_name}.xlsx\")\n",
    "    return result_df"
   ]
